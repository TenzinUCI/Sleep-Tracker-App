# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# API keys
.env
.env.*
!.env.example

server/.env
server/.env.*
!server/.env.example

client/.env
client/.env.*
!client/.env.example

# Compiled output
dist/
tmp/
out-tsc/
bazel-out/
build/
out/

client/dist/
client/tmp/
client/out-tsc/
client/.angular/cache/

server/dist/
server/build/

# Node
node_modules/
**/node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Keep lock files tracked
!package-lock.json
!client/package-lock.json
!server/package-lock.json

# Angular
.angular/cache/
**/.angular/cache/

# Coverage / test output
coverage/
**/coverage/
.nyc_output/
testem.log
__screenshots__/

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json

.history/

# Miscellaneous
.sass-cache/
connect.lock
libpeerconnection.log
typings/

# System files
.DS_Store
Thumbs.db